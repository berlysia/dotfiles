{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "if command -v entire >/dev/null 2>&1; then entire hooks claude-code post-task; fi"
          }
        ]
      },
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "if command -v entire >/dev/null 2>&1; then entire hooks claude-code post-todo; fi"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "if command -v entire >/dev/null 2>&1; then entire hooks claude-code pre-task; fi"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if command -v entire >/dev/null 2>&1; then entire hooks claude-code session-end; fi"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ -n \"${CLAUDE_CODE_REMOTE:-}\" ]]; then mkdir -p ~/.claude/skills ~/.claude/rules \u0026\u0026 cp -rf \"$CLAUDE_PROJECT_DIR\"/dot_claude/skills/* ~/.claude/skills/ \u0026\u0026 cp -rf \"$CLAUDE_PROJECT_DIR\"/dot_claude/rules/* ~/.claude/rules/ \u0026\u0026 echo '[session-start] Skills installed to ~/.claude/' \u003e\u00262; fi"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if command -v entire >/dev/null 2>&1; then entire hooks claude-code session-start; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if command -v entire >/dev/null 2>&1; then entire hooks claude-code stop; fi"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if command -v entire >/dev/null 2>&1; then entire hooks claude-code user-prompt-submit; fi"
          }
        ]
      }
    ]
  },
  "outputStyle": "Explanatory",
  "permissions": {
    "allow": [
      "Bash(bun test *)",
      "Bash(pnpm build *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm lint:fix *)",
      "Bash(pnpm quality-check *)",
      "Bash(pnpm test:ci *)",
      "Bash(pnpm test *)",
      "Bash(pnpm type-check *)",
      "Bash(pnpm typecheck *)",
      "Bash(chezmoi apply *)",
      "Bash(chezmoi data *)",
      "Bash(chezmoi diff *)",
      "Bash(chezmoi execute-template *)",
      "Bash(chezmoi help *)",
      "Bash(chezmoi managed *)",
      "Bash(chezmoi status)",
      "Bash(chezmoi target-path *)",
      "Bash(chezmoi --version)",
      "Bash(mise ls *)",
      "Bash(mise list *)",
      "Bash(mise ls-remote *)",
      "Bash(mise registry *)",
      "Bash(mise reshim *)",
      "Bash(node --test *)",
      "Edit(**/*.test.*)",
      "Read(**/*.test.*)",
      "Read(dot_claude/hooks/**)",
      "Read(~/.local/share/chezmoi/**)",
      "Edit(~/.claude/plans/**)",
      "Write(~/.claude/plans/**)"
    ],
    "deny": [
      "Edit(~/.claude/settings*.json)",
      "Edit(~/.claude/CLAUDE.md)",
      "Edit(~/.claude/.credentials.json)",
      "Edit(~/.claude/commands/**)",
      "Edit(~/.claude/agents/**)",
      "Edit(~/.claude/hooks/**)",
      "Edit(~/.claude/skills/**)",
      "Edit(~/.claude/plugins/**)",
      "Edit(~/.claude/scripts/**)",
      "Edit(~/.claude/lib/**)",
      "Write(~/.claude/settings*.json)",
      "Write(~/.claude/CLAUDE.md)",
      "Write(~/.claude/.credentials.json)",
      "Write(~/.claude/commands/**)",
      "Write(~/.claude/agents/**)",
      "Write(~/.claude/hooks/**)",
      "Write(~/.claude/skills/**)",
      "Write(~/.claude/plugins/**)",
      "Write(~/.claude/scripts/**)",
      "Write(~/.claude/lib/**)",
      "MultiEdit(~/.claude/**)",
      "Read(./.entire/metadata/**)"
    ]
  }
}
