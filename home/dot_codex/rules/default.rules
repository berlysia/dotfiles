# Codex execution policy rules
# Scope: shell commands (execvp) only — does NOT affect file editing tools

# === Safety: dangerous commands ===

prefix_rule(
    pattern = ["rm", "-rf"],
    decision = "forbidden",
    justification = "Recursive force-delete is too dangerous for automated execution",
)

prefix_rule(
    pattern = ["rm", "-r"],
    decision = "prompt",
    justification = "Recursive delete requires human approval",
)

# === Safety: destructive git commands ===

prefix_rule(
    pattern = ["git", "push", "--force"],
    decision = "forbidden",
    justification = "Force-push can destroy remote history",
)

prefix_rule(
    pattern = ["git", "push", "-f"],
    decision = "forbidden",
    justification = "Force-push can destroy remote history",
)

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "prompt",
    justification = "Hard reset discards uncommitted changes — requires human approval",
)

prefix_rule(
    pattern = ["git", "clean", "-f"],
    decision = "prompt",
    justification = "Clean -f removes untracked files — requires human approval",
)

# === Allow: quality commands ===

prefix_rule(
    pattern = ["pnpm", "test"],
    decision = "allow",
    justification = "Running tests is always safe",
)

prefix_rule(
    pattern = ["pnpm", "typecheck"],
    decision = "allow",
    justification = "Type checking is always safe",
)

prefix_rule(
    pattern = ["pnpm", "lint"],
    decision = "allow",
    justification = "Linting is always safe",
)

prefix_rule(
    pattern = ["npx", "biome"],
    decision = "allow",
    justification = "Biome linting/formatting is always safe",
)

prefix_rule(
    pattern = ["npx", "oxlint"],
    decision = "allow",
    justification = "Oxlint is always safe",
)

prefix_rule(
    pattern = ["npx", "shellcheck"],
    decision = "allow",
    justification = "Shellcheck is always safe",
)

# === Allow: read-only git commands ===

prefix_rule(
    pattern = ["git", "status"],
    decision = "allow",
    justification = "Read-only git status",
)

prefix_rule(
    pattern = ["git", "log"],
    decision = "allow",
    justification = "Read-only git log",
)

prefix_rule(
    pattern = ["git", "diff"],
    decision = "allow",
    justification = "Read-only git diff",
)

prefix_rule(
    pattern = ["git", "show"],
    decision = "allow",
    justification = "Read-only git show",
)

prefix_rule(
    pattern = ["git", "rev-parse"],
    decision = "allow",
    justification = "Read-only git rev-parse",
)

prefix_rule(
    pattern = ["git", "branch"],
    decision = "allow",
    justification = "Read-only git branch listing",
)

prefix_rule(
    pattern = ["git", "remote"],
    decision = "allow",
    justification = "Read-only git remote listing",
)

prefix_rule(
    pattern = ["git", "ls-files"],
    decision = "allow",
    justification = "Read-only file listing from git index",
)

# === Allow: test runner ===

prefix_rule(
    pattern = ["node", "--test"],
    decision = "allow",
    justification = "Running tests with node:test is safe",
)

# === Allow: runtime manager (read-only) ===

prefix_rule(
    pattern = ["mise", "list"],
    decision = "allow",
    justification = "Read-only runtime listing",
)

prefix_rule(
    pattern = ["mise", "which"],
    decision = "allow",
    justification = "Read-only command path resolution",
)

# === Allow: chezmoi (read-only) ===

prefix_rule(
    pattern = ["chezmoi", "status"],
    decision = "allow",
    justification = "Read-only chezmoi status",
)

prefix_rule(
    pattern = ["chezmoi", "diff"],
    decision = "allow",
    justification = "Read-only chezmoi diff",
)

prefix_rule(
    pattern = ["chezmoi", "data"],
    decision = "allow",
    justification = "Read-only chezmoi template data",
)
