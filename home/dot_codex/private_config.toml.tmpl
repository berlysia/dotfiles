{{- /* Template content */ -}}
{{- $templateContent := include "dot_codex/.config.toml" | replace "__CHEZMOI_HOME__" .chezmoi.homeDir -}}
{{- $targetFile := joinPath .chezmoi.homeDir ".codex" "config.toml" -}}
{{- $mergeScript := joinPath .chezmoi.homeDir ".codex" ".merge-config.ts" -}}

{{- /* Check if target file exists */ -}}
{{- if stat $targetFile -}}
  {{- /* Target file exists, smart merge with existing user settings */ -}}
  {{- $shellScript := `
set -euo pipefail

TARGET_FILE="$1"
TEMPLATE_CONTENT="$2"
MERGE_SCRIPT="$3"
TEMP_TOML=$(mktemp /tmp/codex-tpl.XXXXXX.toml)
trap 'rm -f "$TEMP_TOML"' EXIT

printf '%s' "$TEMPLATE_CONTENT" > "$TEMP_TOML"

if ! command -v bun &>/dev/null || [ ! -f "$MERGE_SCRIPT" ]; then
    cat "$TEMP_TOML"
    exit 0
fi

bun run "$MERGE_SCRIPT" "$TARGET_FILE" "$TEMP_TOML"
` -}}
  {{- output "bash" "-c" $shellScript "--" $targetFile $templateContent $mergeScript -}}
{{- else -}}
  {{- /* Target file doesn't exist, output template as-is */ -}}
  {{- $templateContent -}}
{{- end -}}
