{{ if ne .chezmoi.os "windows" }}
[".zsh/ni.zsh"]
type = "file"
url = "https://raw.githubusercontent.com/azu/ni.zsh/main/ni.zsh"
refreshPeriod = "24h"
# fzf is now managed by mise - see ~/.config/mise/config.toml
{{ end }}

{{/* ui-skills: Opinionated constraints for building better interfaces */}}
{{/* Downloaded directly to ~/.claude/skills/, excluded from rsync */}}
[".claude/skills/ui-skills/SKILL.md"]
type = "file"
url = "https://ui-skills.com/llms.txt"
refreshPeriod = "168h" # 1 week

{{/* wsl2-ssh-agent is only needed in WSL2 environment */}}
{{ if and (eq .chezmoi.os "linux") (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
[".local/bin/wsl2-ssh-agent"]
type = "file"
url = "https://github.com/mame/wsl2-ssh-agent/releases/latest/download/wsl2-ssh-agent"
refreshPeriod = "24h"
executable = true
{{/* wsl-notify-send: installed via run_onchange script to Windows PATH */}}
{{ end }}

{{/* rtk: Rust CLI proxy that reduces LLM token consumption 60-90% */}}
{{/* Pinned to v0.35.0 - bump manually after reviewing upstream hook script */}}
{{ if eq .chezmoi.os "linux" -}}
{{ if eq .chezmoi.arch "amd64" }}
[".local/bin/rtk"]
type = "archive-file"
url = "https://github.com/rtk-ai/rtk/releases/download/v0.35.0/rtk-x86_64-unknown-linux-musl.tar.gz"
path = "rtk"
executable = true
refreshPeriod = "168h"
{{ else if eq .chezmoi.arch "arm64" }}
[".local/bin/rtk"]
type = "archive-file"
url = "https://github.com/rtk-ai/rtk/releases/download/v0.35.0/rtk-aarch64-unknown-linux-gnu.tar.gz"
path = "rtk"
executable = true
refreshPeriod = "168h"
{{ end }}
{{ end }}
{{ if eq .chezmoi.os "darwin" -}}
{{ if eq .chezmoi.arch "amd64" }}
[".local/bin/rtk"]
type = "archive-file"
url = "https://github.com/rtk-ai/rtk/releases/download/v0.35.0/rtk-x86_64-apple-darwin.tar.gz"
path = "rtk"
executable = true
refreshPeriod = "168h"
{{ else if eq .chezmoi.arch "arm64" }}
[".local/bin/rtk"]
type = "archive-file"
url = "https://github.com/rtk-ai/rtk/releases/download/v0.35.0/rtk-aarch64-apple-darwin.tar.gz"
path = "rtk"
executable = true
refreshPeriod = "168h"
{{ end }}
{{ end }}
