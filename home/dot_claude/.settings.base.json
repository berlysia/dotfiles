{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "alwaysThinkingEnabled": true,
  "plansDirectory": "./.claude/plans",
  "language": "japanese",
  "autoMemoryEnabled": false,
  "defaultMode": "auto",
  "skipAutoPermissionPrompt": true
}
