{{ if ne .chezmoi.os "windows" -}}
#!/bin/bash
# Install node_modules for chezmoi source directory (root workspace)
# package.json hash: {{ output "cat" (joinPath .chezmoi.workingTree "package.json") | sha256sum }}
# bun.lock hash: {{ output "cat" (joinPath .chezmoi.workingTree "bun.lock") | sha256sum }}

set -euo pipefail

log() {
    local level="${2:-INFO}"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [$level] $1"
}

SOURCE_DIR="{{ .chezmoi.workingTree }}"

# Initialize mise environment to access bun
if command -v mise &> /dev/null; then
    if mise_env=$(mise env --shell bash 2>/dev/null); then
        eval "$mise_env"
    fi
fi

if ! command -v bun &> /dev/null; then
    log "bun not found. Skipping node_modules install." "WARNING"
    log "Run 'mise install' to install bun first." "INFO"
    exit 0
fi

log "Installing node_modules in $SOURCE_DIR..."
if (cd "$SOURCE_DIR" && bun install --frozen-lockfile 2>&1); then
    log "Successfully installed node_modules" "SUCCESS"
else
    log "frozen-lockfile failed. Run 'bun install' manually to update bun.lock" "ERROR"
    exit 1
fi

log "node_modules installation completed"
{{ end -}}
