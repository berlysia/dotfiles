{{- if and (eq .chezmoi.os "darwin") .mcp.shared_mode -}}
#!/bin/bash
# Ensure MCP launchd agents are loaded after chezmoi deploys plist files
# Runs after every chezmoi apply but skips healthy services

set -euo pipefail

LAUNCH_AGENTS_DIR="$HOME/Library/LaunchAgents"
DOMAIN="gui/$(id -u)"

MCP_LABELS="com.berlysia.mcp-readability com.berlysia.mcp-context7 com.berlysia.mcp-drawio"
MCP_PORTS="18101 18102 18103"

changed=0
i=0
for label in $MCP_LABELS; do
    port=$(echo $MCP_PORTS | cut -d' ' -f$((i+1)))
    i=$((i+1))
    plist="$LAUNCH_AGENTS_DIR/${label}.plist"

    if [ ! -f "$plist" ]; then
        continue
    fi

    # Skip if already healthy
    if curl -s --max-time 1 "http://localhost:${port}/healthz" >/dev/null 2>&1; then
        continue
    fi

    # Not healthy — (re)load
    echo "Loading $label on port $port..."
    launchctl bootout "$DOMAIN/$label" 2>/dev/null || true
    if launchctl bootstrap "$DOMAIN" "$plist" 2>&1; then
        echo "  loaded: $label"
        changed=1
    else
        echo "  FAILED: $label"
    fi
done

if [ $changed -eq 1 ]; then
    sleep 3
    i=0
    for label in $MCP_LABELS; do
        port=$(echo $MCP_PORTS | cut -d' ' -f$((i+1)))
        i=$((i+1))
        if curl -s --max-time 2 "http://localhost:${port}/healthz" >/dev/null 2>&1; then
            echo "  healthy: $label (port $port)"
        else
            echo "  WARNING: $label not responding on port $port"
        fi
    done
fi
{{- end -}}
